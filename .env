# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Domain ────────────────────────────────────────────────────────────────────
# Your primary short domain
BASE_DOMAIN=axexvx.link

# Comma-separated list of allowed CORS origins (use * for all)
ALLOWED_ORIGINS=https://axexvx.link,https://www.axexvx.link

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database is stored at ./data/axexvx.db by default
# No additional config needed for SQLite

# ── Optional: SMS Provider (e.g. Twilio) ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890

# ── Optional: Rate Limiting ───────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
